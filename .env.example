# whatsapp-pi Environment Variables

# Server Configuration
PORT=3001
NODE_ENV=development

# Database
DATABASE_URL=./data/whatsapp.db

# Vector Index / Embeddings
EMBEDDING_MODEL=Xenova/all-MiniLM-L6-v2

# WhatsApp Session Info
# Used for initial auth folder location
WA_AUTH_DATA_DIR=./data/wa-auth
