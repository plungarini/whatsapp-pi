{
  "name": "whatsapp-pi",
  "version": "1.3.0",
  "description": "WhatsApp microservice",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev:server": "ts-node-dev --respawn --transpile-only src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "onboard": "node scripts/onboard.js",
    "setup:vec": "npm install sqlite-vec"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@hapi/boom": "^10.0.1",
    "@whiskeysockets/baileys": "^6.7.12",
    "better-sqlite3": "^11.8.1",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "qrcode-terminal": "^0.12.0",
    "sqlite-vec": "^0.1.6"
  },
  "optionalDependencies": {
    "sqlite-vec-linux-arm64": "0.1.6",
    "sqlite-vec-linux-x64": "0.1.6",
    "sqlite-vec-darwin-arm64": "0.1.6",
    "sqlite-vec-darwin-x64": "0.1.6",
    "sqlite-vec-windows-x64": "0.1.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.13.4",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
